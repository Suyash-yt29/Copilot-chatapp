# Production Environment Configuration
# Copy this to .env and fill in your production values

NODE_ENV=production
PORT=5000
API_URL=https://yourdomain.com

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=chatapp
DB_USER=chatapp
DB_PASSWORD=generate_secure_password_here
DB_POOL_MIN=10
DB_POOL_MAX=20

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=generate_secure_password_here

# JWT Configuration
JWT_ACCESS_SECRET=generate_32_character_random_string_here
JWT_REFRESH_SECRET=generate_32_character_random_string_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# S3 Configuration
S3_ENDPOINT=https://s3.amazonaws.com
S3_ACCESS_KEY=your_s3_access_key
S3_SECRET_KEY=your_s3_secret_key
S3_BUCKET=chatapp-prod
S3_REGION=us-east-1

# CORS Configuration
CORS_ORIGIN=https://yourdomain.com

# File Upload
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,video/mp4,application/pdf

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# Frontend URLs
VITE_API_URL=https://yourdomain.com/api
VITE_SOCKET_URL=https://yourdomain.com
